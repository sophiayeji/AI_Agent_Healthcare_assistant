import React, { useState, useRef, useEffect } from "react";
import { 
  Upload, 
  Clipboard, 
  CheckCircle, 
  FileSpreadsheet, 
  FileText, 
  AlertCircle, 
  Sparkles, 
  Info,
  Check,
  ChevronRight
} from "lucide-react";
import { 
  parsePatientDemographics, 
  parseStaffData, 
  parseDepartmentPerformance, 
  parseMonthlyTrends 
} from "../utils/csvParser";
import { DashboardData } from "../types";
import { defaultDashboardData } from "../defaultData";

interface CsvUploaderProps {
  draftState: DashboardData;
  setDraftState: React.Dispatch<React.SetStateAction<DashboardData>>;
  onNotify: (msg: string, type: "success" | "error" | "info") => void;
}

type TabType = "patients" | "staff" | "performance" | "trends";

export default function CsvUploader({ draftState, setDraftState, onNotify }: CsvUploaderProps) {
  const [activeTab, setActiveTab] = useState<TabType>("patients");
  const [dragActive, setDragActive] = useState(false);
  const [pasteText, setPasteText] = useState("");
  const [pasteType, setPasteType] = useState<"auto" | TabType>("auto");
  const fileInputRef = useRef<HTMLInputElement>(null);

  const [uploadedStatus, setUploadedStatus] = useState({
    patients: false,
    staff: false,
    performance: false,
    trends: false
  });

  // Automatically reset indicators when the draft state is reverted to the default high-fidelity baseline
  useEffect(() => {
    const isDefault = JSON.stringify(draftState.staffData) === JSON.stringify(defaultDashboardData.staffData);
    if (isDefault) {
      setUploadedStatus({
        patients: false,
        staff: false,
        performance: false,
        trends: false
      });
    }
  }, [draftState]);

  // Schema templates
  const templates = {
    patients: `Category,Count
0-18,1240
19-35,2150
36-50,3420
51-65,4890
66+,6120
Emergency,5800
Cardiology,2400
Pediatrics,1900
Orthopedics,3100
General Surgery,2800
ICU,1820`,

    staff: `Department,Staff Count,Presence Rate %
Emergency,120,88
Cardiology,45,94
Pediatrics,35,91
Orthopedics,40,86
General Surgery,50,89
ICU,65,84`,

    performance: `Department,Request to Admission %,Service Availability %,Satisfaction Score,Avg Length of Stay (Days)
Emergency,42,81,3.8,1.2
Cardiology,78,95,4.6,6.8
Pediatrics,60,92,4.5,3.1
Orthopedics,68,87,4.1,5.4
General Surgery,82,89,4.3,4.8
ICU,91,78,3.9,8.5`,

    trends: `Month,Requests,Admissions,Availability %,Avg Length of Stay,Satisfaction,Discharges,Readmission Rate %
January,3200,2080,91,4.8,4.3,1980,4.2
February,3400,2140,89,4.9,4.2,2050,4.5
March,3800,2280,86,5.2,4.1,2120,5.1
April,4100,2337,83,5.5,3.9,2210,5.8
May,4500,2475,80,5.9,3.8,2320,6.4`
  };

  // Heuristic-based CSV schema auto-detection
  const detectCsvType = (text: string, fileName: string = ""): TabType | null => {
    const normalizedText = text.toLowerCase();
    const normalizedFileName = fileName.toLowerCase();

    // 1. Check filename keyword hints
    if (normalizedFileName.includes("demographic") || normalizedFileName.includes("patient") || normalizedFileName.includes("age")) {
      return "patients";
    }
    if (normalizedFileName.includes("staff") || normalizedFileName.includes("nurs") || normalizedFileName.includes("avail")) {
      if (normalizedFileName.includes("performance") || normalizedFileName.includes("trend")) {
        // bypass
      } else {
        return "staff";
      }
    }
    if (normalizedFileName.includes("perf") || normalizedFileName.includes("depart")) {
      if (!normalizedFileName.includes("staff")) {
        return "performance";
      }
    }
    if (normalizedFileName.includes("trend") || normalizedFileName.includes("month") || normalizedFileName.includes("ytd")) {
      return "trends";
    }

    // 2. Check header content
    const lines = text.split(/\r?\n/).map(line => line.trim()).filter(line => line.length > 0);
    if (lines.length === 0) return null;

    const firstLine = lines[0].toLowerCase();

    if (firstLine.includes("patient_id")) {
      return "patients";
    }
    if (firstLine.includes("staff_id") || firstLine.includes("present")) {
      return "staff";
    }
    if (firstLine.includes("available_beds") || firstLine.includes("patients_request") || firstLine.includes("patients_refused")) {
      return "performance";
    }
    if (firstLine.includes("presence rate") || firstLine.includes("staff count")) {
      return "staff";
    }
    if (firstLine.includes("request to admission") || firstLine.includes("satisfaction score") || firstLine.includes("avg length of stay")) {
      return "performance";
    }
    if (firstLine.includes("readmission rate") || (firstLine.includes("month") && firstLine.includes("requests") && firstLine.includes("admissions"))) {
      return "trends";
    }
    if (firstLine.includes("category") || firstLine.includes("count")) {
      return "patients";
    }

    // 3. Fallback Row Checks
    for (let i = 1; i < Math.min(lines.length, 6); i++) {
      const row = lines[i].toLowerCase();
      if (row.includes("0-18") || row.includes("19-35") || row.includes("36-50") || row.includes("51-65") || row.includes("66+")) {
        return "patients";
      }
      if (row.includes("january") || row.includes("february") || row.includes("march") || row.includes("april") || row.includes("may")) {
        return "trends";
      }
    }

    // Simple column count heuristics
    const headerCols = firstLine.split(",");
    if (headerCols.length === 3 && firstLine.includes("department")) {
      return "staff";
    }
    if (headerCols.length >= 5 && firstLine.includes("department")) {
      return "performance";
    }

    return null;
  };

  const copyTemplateToClipboard = (type: TabType) => {
    navigator.clipboard.writeText(templates[type]);
    const readableName = 
      type === "patients" ? "Patient Demographics" : 
      type === "staff" ? "Staff Availability" : 
      type === "performance" ? "Department Performance" : 
      "Monthly Trends";
    onNotify(`${readableName} CSV template copied to clipboard!`, "success");
  };

  const handleDrag = (e: React.DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
    if (e.type === "dragenter" || e.type === "dragover") {
      setDragActive(true);
    } else if (e.type === "dragleave") {
      setDragActive(false);
    }
  };

  // Central process function for parsed text
  const processCsvText = (text: string, forceType?: TabType, fileName?: string): { success: boolean; type?: TabType; message?: string } => {
    if (!text.trim()) {
      return { success: false, message: "CSV content is empty." };
    }

    // Detect type
    const type = forceType || detectCsvType(text, fileName);
    if (!type) {
      return { success: false, message: "Could not auto-detect schema. Please choose a target type or check column names." };
    }

    // Extract year from CSV content or filename
    const yearRegex = /\b(202\d|201\d)\b/;
    const fileYearMatch = fileName ? fileName.match(yearRegex) : null;
    const textYearMatch = text.match(yearRegex);
    const yearStr = fileYearMatch ? fileYearMatch[1] : (textYearMatch ? textYearMatch[1] : "2026");
    const yearShort = yearStr.slice(-2);

    try {
      if (type === "patients") {
        const parsed = parsePatientDemographics(text);
        if (parsed) {
          let computedPeriod = parsed.period;
          if (computedPeriod && yearStr !== "2026") {
            computedPeriod = computedPeriod.replace(/26/g, yearShort).replace(/25/g, yearShort);
          }
          setDraftState(prev => ({
            ...prev,
            patientDemographics: parsed.patientDemographics,
            ...(parsed.lengthOfStaySatisfaction ? { lengthOfStaySatisfaction: parsed.lengthOfStaySatisfaction } : {}),
            period: computedPeriod || prev.period
          }));
          setUploadedStatus(prev => ({ ...prev, patients: true }));
          return { success: true, type, message: "Successfully parsed and loaded Patient Demographics." };
        }
      } else if (type === "staff") {
        const parsed = parseStaffData(text);
        if (parsed) {
          setDraftState(prev => ({
            ...prev,
            staffData: parsed
          }));
          setUploadedStatus(prev => ({ ...prev, staff: true }));
          return { success: true, type, message: "Successfully parsed and loaded Staff Availability." };
        }
      } else if (type === "performance") {
        const parsed = parseDepartmentPerformance(text);
        if (parsed) {
          let computedPeriod = parsed.period;
          if (!computedPeriod && parsed.monthlyTrends && parsed.monthlyTrends.length > 0) {
            const monthToNumAndDays: { [key: string]: { num: string, days: string } } = {
              "january": { num: "01", days: "31" },
              "february": { num: "02", days: "28" },
              "march": { num: "03", days: "31" },
              "april": { num: "04", days: "30" },
              "may": { num: "05", days: "31" },
              "june": { num: "06", days: "30" },
              "july": { num: "07", days: "31" },
              "august": { num: "08", days: "31" },
              "september": { num: "09", days: "30" },
              "october": { num: "10", days: "31" },
              "november": { num: "11", days: "30" },
              "december": { num: "12", days: "31" }
            };
            const monthsOrder = ["january", "february", "march", "april", "may", "june", "july", "august", "september", "october", "november", "december"];
            const parsedMonths = parsed.monthlyTrends.map(p => p.month.toLowerCase()).filter(m => monthsOrder.includes(m));
            parsedMonths.sort((a, b) => monthsOrder.indexOf(a) - monthsOrder.indexOf(b));
            if (parsedMonths.length > 0) {
              const firstM = parsedMonths[0];
              const lastM = parsedMonths[parsedMonths.length - 1];
              const firstNum = monthToNumAndDays[firstM]?.num || "01";
              const lastNum = monthToNumAndDays[lastM]?.num || "12";
              const lastDay = monthToNumAndDays[lastM]?.days || "31";
              computedPeriod = `${firstNum}/01/${yearShort} – ${lastNum}/${lastDay}/${yearShort}`;
            }
          } else if (computedPeriod) {
            if (yearStr !== "2026") {
              computedPeriod = computedPeriod.replace(/26/g, yearShort).replace(/25/g, yearShort);
            }
          }

          setDraftState(prev => ({
            ...prev,
            departmentPerformance: parsed.performance,
            lengthOfStaySatisfaction: parsed.los,
            ...(parsed.monthlyTrends ? { monthlyTrends: parsed.monthlyTrends } : {}),
            period: computedPeriod || prev.period
          }));
          setUploadedStatus(prev => ({ 
            ...prev, 
            performance: true,
            ...(parsed.monthlyTrends ? { trends: true } : {})
          }));
          return { success: true, type, message: "Successfully parsed and loaded Department Performance metrics." };
        }
      } else if (type === "trends") {
        const parsed = parseMonthlyTrends(text);
        if (parsed) {
          const monthToNumAndDays: { [key: string]: { num: string, days: string } } = {
            "january": { num: "01", days: "31" },
            "february": { num: "02", days: "28" },
            "march": { num: "03", days: "31" },
            "april": { num: "04", days: "30" },
            "may": { num: "05", days: "31" },
            "june": { num: "06", days: "30" },
            "july": { num: "07", days: "31" },
            "august": { num: "08", days: "31" },
            "september": { num: "09", days: "30" },
            "october": { num: "10", days: "31" },
            "november": { num: "11", days: "30" },
            "december": { num: "12", days: "31" }
          };
          
          const monthsOrder = ["january", "february", "march", "april", "may", "june", "july", "august", "september", "october", "november", "december"];
          const parsedMonths = parsed.map(p => p.month.toLowerCase()).filter(m => monthsOrder.includes(m));
          parsedMonths.sort((a, b) => monthsOrder.indexOf(a) - monthsOrder.indexOf(b));
          
          let computedPeriod = `01/01/${yearShort} – 12/31/${yearShort}`;
          if (parsedMonths.length > 0) {
            const firstM = parsedMonths[0];
            const lastM = parsedMonths[parsedMonths.length - 1];
            const firstNum = monthToNumAndDays[firstM]?.num || "01";
            const lastNum = monthToNumAndDays[lastM]?.num || "12";
            const lastDay = monthToNumAndDays[lastM]?.days || "31";
            computedPeriod = `${firstNum}/01/${yearShort} – ${lastNum}/${lastDay}/${yearShort}`;
          }

          setDraftState(prev => ({
            ...prev,
            monthlyTrends: parsed,
            period: computedPeriod
          }));
          setUploadedStatus(prev => ({ ...prev, trends: true }));
          return { success: true, type, message: "Successfully parsed and loaded Monthly Admission Trends." };
        }
      }
      return { success: false, message: `Could not parse data using the ${type} schema.` };
    } catch (err: any) {
      return { success: false, message: err.message || "Unknown error during CSV parsing." };
    }
  };

  const handleFilesList = (files: FileList) => {
    let successCount = 0;
    let failureCount = 0;

    Array.from(files).forEach(file => {
      const reader = new FileReader();
      reader.onload = (event) => {
        const text = event.target?.result as string;
        const result = processCsvText(text, undefined, file.name);
        
        if (result.success) {
          successCount++;
          const readableType = 
            result.type === "patients" ? "Patient Demographics" : 
            result.type === "staff" ? "Staff Availability" : 
            result.type === "performance" ? "Department Performance" : 
            "Monthly Trends";
          onNotify(`Uploaded ${file.name} successfully mapped to [${readableType}]`, "success");
          
          // Auto-focus on the table tab for the uploaded type to let admin inspect immediately!
          if (result.type) {
            setActiveTab(result.type);
          }
        } else {
          failureCount++;
          onNotify(`Failed to parse ${file.name}: ${result.message}`, "error");
        }
      };
      reader.readAsText(file);
    });
  };

  const handleDrop = (e: React.DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
    setDragActive(false);

    if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
      handleFilesList(e.dataTransfer.files);
    }
  };

  const handleFileChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    if (e.target.files && e.target.files.length > 0) {
      handleFilesList(e.target.files);
    }
  };

  const triggerFileSelect = () => {
    fileInputRef.current?.click();
  };

  const handlePasteSubmit = () => {
    const selectedType = pasteType === "auto" ? undefined : pasteType;
    const result = processCsvText(pasteText, selectedType);
    if (result.success) {
      const readableType = 
        result.type === "patients" ? "Patient Demographics" : 
        result.type === "staff" ? "Staff Availability" : 
        result.type === "performance" ? "Department Performance" : 
        "Monthly Trends";
      onNotify(`Successfully pasted and mapped to ${readableType}!`, "success");
      setPasteText("");
      if (result.type) {
        setActiveTab(result.type);
      }
    } else {
      onNotify(`Paste parsing failed: ${result.message}`, "error");
    }
  };

  return (
    <div className="bg-white rounded-xl shadow-sm border border-[#E3E8EE] overflow-hidden" id="csv-uploader-module">
      {/* Module Title Header */}
      <div className="border-b border-[#E3E8EE] bg-[#F7FAFC] p-6">
        <div className="flex items-center gap-3">
          <div className="p-2.5 bg-[#4F46E5] text-white rounded-lg shadow-sm">
            <FileSpreadsheet size={20} />
          </div>
          <div>
            <h3 className="font-bold text-[#1A1F36] text-lg">Hospital Operations Data Ingestion Hub</h3>
            <p className="text-xs text-[#697386]">
              Upload, drop, or paste multiple CSV operational datasets simultaneously. Our system automatically parses headers and maps them to the correct dashboard modules.
            </p>
          </div>
        </div>
      </div>

      <div className="p-6 space-y-6">
        {/* Main Single Master Upload Area */}
        <div className="grid grid-cols-1 lg:grid-cols-12 gap-6">
          
          {/* Dragger Dropzone container */}
          <div className="lg:col-span-8 flex flex-col gap-4">
            <div
              onDragEnter={handleDrag}
              onDragOver={handleDrag}
              onDragLeave={handleDrag}
              onDrop={handleDrop}
              onClick={triggerFileSelect}
              className={`border-2 border-dashed rounded-xl p-8 flex flex-col items-center justify-center text-center cursor-pointer transition-all min-h-[200px] ${
                dragActive 
                  ? "border-[#4F46E5] bg-[#F0F4FF]" 
                  : "border-[#CBD5E0] hover:border-[#4F46E5] hover:bg-[#F7FAFC]"
              }`}
            >
              <input
                type="file"
                ref={fileInputRef}
                onChange={handleFileChange}
                accept=".csv"
                multiple
                className="hidden"
              />
              <div className="p-4 bg-[#F0F4FF] text-[#4F46E5] rounded-full mb-3 shadow-inner">
                <Upload size={28} />
              </div>
              <p className="text-sm font-bold text-[#1A1F36] mb-1">
                Drag and drop your CSV files here
              </p>
              <p className="text-xs text-[#697386] mb-2 max-w-md">
                Select or drop one or multiple CSVs at once. We auto-detect Demographics, Staffing, Performance, and Monthly Trends.
              </p>
              <span className="text-[10px] bg-slate-100 px-3 py-1 text-[#4A5568] rounded-full border border-slate-200 font-semibold uppercase tracking-wider">
                Support Multi-File Upload
              </span>
            </div>

            {/* Quick Manual Paste Fallback */}
            <div className="bg-[#F7FAFC] p-4 rounded-xl border border-[#E3E8EE] space-y-3">
              <div className="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2">
                <label className="text-xs font-bold text-[#1A1F36] uppercase tracking-wider flex items-center gap-1.5">
                  <FileText size={13} className="text-[#4F46E5]" />
                  <span>Manual Raw CSV Paste:</span>
                </label>
                
                <div className="flex items-center gap-2 w-full sm:w-auto">
                  <span className="text-[10px] text-[#697386] font-medium hidden sm:inline">Schema Type:</span>
                  <select
                    value={pasteType}
                    onChange={(e) => setPasteType(e.target.value as any)}
                    className="bg-white border border-[#E3E8EE] rounded-lg px-2 py-1 text-xs text-[#1A1F36] focus:outline-none focus:border-[#4F46E5] font-medium"
                  >
                    <option value="auto">Auto-Detect Schema</option>
                    <option value="patients">1. Patient Demographics</option>
                    <option value="staff">2. Staff Availability</option>
                    <option value="performance">3. Department Performance</option>
                    <option value="trends">4. Monthly Trends</option>
                  </select>
                </div>
              </div>

              <div className="relative">
                <textarea
                  value={pasteText}
                  onChange={(e) => setPasteText(e.target.value)}
                  placeholder={`Paste comma-separated rows. E.g.:\nCategory,Count\n0-18,1240\n19-35,2150`}
                  rows={3}
                  className="w-full font-mono text-xs p-3 border border-[#E3E8EE] rounded-lg focus:outline-none focus:ring-1 focus:ring-[#4F46E5] bg-white text-[#1A1F36]"
                />
                <button
                  onClick={handlePasteSubmit}
                  disabled={!pasteText.trim()}
                  className="absolute bottom-3 right-3 py-1.5 px-3 bg-[#4F46E5] hover:bg-[#3730A3] text-white rounded text-xs font-semibold flex items-center gap-1 shadow-sm transition-all disabled:opacity-50 disabled:cursor-not-allowed"
                >
                  <CheckCircle size={12} />
                  <span>Parse & Ingest</span>
                </button>
              </div>
            </div>
          </div>

          {/* Dataset Status Dashboard Box */}
          <div className="lg:col-span-4 flex flex-col justify-between bg-[#F7FAFC] rounded-xl p-5 border border-[#E3E8EE] gap-4">
            <div className="space-y-3">
              <h4 className="text-xs font-bold text-[#1A1F36] uppercase tracking-wider border-b border-[#E3E8EE] pb-2 flex items-center gap-2">
                <Sparkles size={14} className="text-[#4F46E5]" />
                <span>Sandbox Datasets Status</span>
              </h4>
              <p className="text-[11px] text-[#697386] leading-normal">
                Review which elements of the executive portal sandbox are currently updated with custom uploads vs default benchmarks.
              </p>
            </div>

            {/* Status indicators and Quick Copy buttons for templates */}
            <div className="space-y-2.5">
              {[
                { key: "patients" as TabType, label: "Patient Demographics", desc: "Age ratios & clinical volumes" },
                { key: "staff" as TabType, label: "Staff Availability", desc: "Headcount & nurse presence rates" },
                { key: "performance" as TabType, label: "Department Performance", desc: "LOS & satisfaction indexes" },
                { key: "trends" as TabType, label: "Monthly Trends", desc: "Historical YTD admissions" }
              ].map((item, idx) => {
                const isUploaded = uploadedStatus[item.key];
                return (
                  <div key={item.key} className="bg-white p-2.5 rounded-lg border border-[#E3E8EE] flex items-center justify-between gap-3">
                    <div className="flex items-center gap-2">
                      <div className={`p-1 rounded-full ${isUploaded ? "bg-[#DCFCE7] text-[#166534]" : "bg-slate-100 text-slate-400"}`}>
                        {isUploaded ? <Check size={12} /> : <div className="w-3 h-3 border border-slate-300 rounded-full" />}
                      </div>
                      <div>
                        <div className="text-xs font-bold text-[#1A1F36] flex items-center gap-1">
                          <span>{idx + 1}. {item.label}</span>
                        </div>
                        <span className="text-[9px] text-[#697386] block font-medium leading-none">{item.desc}</span>
                      </div>
                    </div>
                    
                    <button
                      onClick={() => copyTemplateToClipboard(item.key)}
                      className="text-[10px] text-[#4F46E5] hover:text-[#3730A3] font-bold uppercase tracking-wider bg-indigo-50/50 hover:bg-indigo-50 px-2 py-1 rounded border border-indigo-100"
                      title="Copy standard CSV mock data template for this schema"
                    >
                      Copy Template
                    </button>
                  </div>
                );
              })}
            </div>

            <div className="p-3 bg-white border border-[#E3E8EE] rounded-lg flex items-start gap-2">
              <Info size={14} className="text-[#4F46E5] shrink-0 mt-0.5" />
              <p className="text-[10px] text-[#697386] leading-relaxed">
                Tip: Copy templates to create your own CSV spreadsheets locally. Drop them back here to quickly test live changes.
              </p>
            </div>
          </div>

        </div>

        {/* Tabbed Preview Grid of formatted tables underneath */}
        <div className="border-t border-[#E3E8EE] pt-6 space-y-4">
          <div className="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
            <div className="space-y-0.5">
              <h4 className="font-bold text-sm text-[#1A1F36] flex items-center gap-1.5">
                <span>Detailed Workspace Tables</span>
                <span className="text-[10px] bg-[#F7FAFC] border border-[#E3E8EE] py-0.5 px-2 rounded font-mono text-[#697386]">Live Inspector</span>
              </h4>
              <p className="text-xs text-[#697386]">Click the tabs below to inspect the parsed data records currently active inside the sandboxed state.</p>
            </div>

            {/* In-memory preview table tabs selector */}
            <div className="flex flex-wrap bg-[#F0F2F5] p-1 rounded-lg border border-[#E3E8EE] gap-1">
              {([
                { key: "patients" as TabType, label: "Demographics" },
                { key: "staff" as TabType, label: "Staff" },
                { key: "performance" as TabType, label: "Performance" },
                { key: "trends" as TabType, label: "Monthly Trends" }
              ]).map(tab => (
                <button
                  key={tab.key}
                  onClick={() => setActiveTab(tab.key)}
                  className={`py-1 px-3 text-[11px] font-semibold rounded-md transition-all ${
                    activeTab === tab.key
                      ? "bg-white text-[#4F46E5] shadow-sm font-bold border border-slate-200/50"
                      : "text-[#697386] hover:text-[#1A1F36]"
                  }`}
                >
                  {tab.label}
                </button>
              ))}
            </div>
          </div>

          {/* Formatted tabular preview */}
          <div className="overflow-x-auto border border-[#E3E8EE] rounded-xl bg-white shadow-sm">
            <table className="w-full text-left border-collapse text-xs">
              <thead>
                <tr className="bg-[#F7FAFC] border-b border-[#E3E8EE] text-[#697386] font-bold">
                  {activeTab === "patients" && (
                    <>
                      <th className="p-3">Record Type</th>
                      <th className="p-3">Category/Service Line</th>
                      <th className="p-3 text-right">Patient Volume Count</th>
                    </>
                  )}
                  {activeTab === "staff" && (
                    <>
                      <th className="p-3">Department Unit</th>
                      <th className="p-3 text-right">Active Staff Count (FTEs)</th>
                      <th className="p-3 text-right">Average Presence Rate</th>
                    </>
                  )}
                  {activeTab === "performance" && (
                    <>
                      <th className="p-3">Department Unit</th>
                      <th className="p-3 text-right">Intake-to-Admission Rate</th>
                      <th className="p-3 text-right">Service Availability</th>
                      <th className="p-3 text-right">Patient Satisfaction Score</th>
                      <th className="p-3 text-right">Average Length of Stay (LOS)</th>
                    </>
                  )}
                  {activeTab === "trends" && (
                    <>
                      <th className="p-3">Period Month</th>
                      <th className="p-3 text-right">Incoming Inquiries/Requests</th>
                      <th className="p-3 text-right">Total Admissions</th>
                      <th className="p-3 text-right">Service Availability Rate</th>
                      <th className="p-3 text-right">Average Length of Stay</th>
                      <th className="p-3 text-right">Satisfaction Level</th>
                    </>
                  )}
                </tr>
              </thead>
              <tbody className="divide-y divide-[#E3E8EE] text-[#4A5568] font-medium">
                {activeTab === "patients" && (
                  <>
                    {draftState.patientDemographics.ageGroups.map((a, i) => (
                      <tr key={`age-${i}`} className="hover:bg-[#F7FAFC]">
                        <td className="p-3 font-semibold text-indigo-600">Age Distribution</td>
                        <td className="p-3">{a.group}</td>
                        <td className="p-3 text-right font-mono text-[#1A1F36]">{a.count.toLocaleString()} patients</td>
                      </tr>
                    ))}
                    {draftState.patientDemographics.serviceTypes.map((s, i) => (
                      <tr key={`service-${i}`} className="hover:bg-[#F7FAFC]">
                        <td className="p-3 font-semibold text-[#10B981]">Specialty Clinic Volume</td>
                        <td className="p-3">{s.service}</td>
                        <td className="p-3 text-right font-mono text-[#1A1F36]">{s.count.toLocaleString()} patients</td>
                      </tr>
                    ))}
                  </>
                )}

                {activeTab === "staff" && 
                  draftState.staffData.map((s, i) => (
                    <tr key={`staff-${i}`} className="hover:bg-[#F7FAFC]">
                      <td className="p-3 font-semibold text-[#1A1F36]">{s.department}</td>
                      <td className="p-3 text-right font-mono">{s.staffCount} FTEs</td>
                      <td className="p-3 text-right">
                        <span className="font-mono font-bold text-[#4F46E5]">{s.presenceRate}%</span>
                        <div className="inline-block w-16 h-2 bg-slate-100 rounded-full overflow-hidden ml-2.5 border border-[#E3E8EE]">
                          <div className="h-full bg-[#4F46E5] rounded-full" style={{ width: `${s.presenceRate}%` }} />
                        </div>
                      </td>
                    </tr>
                  ))
                }

                {activeTab === "performance" && 
                  draftState.departmentPerformance.map((dp, i) => {
                    const losItem = draftState.lengthOfStaySatisfaction.find(l => l.serviceType === dp.department);
                    return (
                      <tr key={`perf-${i}`} className="hover:bg-[#F7FAFC]">
                        <td className="p-3 font-semibold text-[#1A1F36]">{dp.department}</td>
                        <td className="p-3 text-right font-mono">{dp.requestToAdmissionRate}%</td>
                        <td className="p-3 text-right">
                          <span className={`font-mono font-bold ${dp.serviceAvailability < 80 ? "text-[#991B1B]" : "text-[#166534]"}`}>
                            {dp.serviceAvailability}%
                          </span>
                        </td>
                        <td className="p-3 text-right font-mono">{dp.satisfactionScore} / 5.0</td>
                        <td className="p-3 text-right font-mono">{losItem ? losItem.averageLOS : "N/A"} Days</td>
                      </tr>
                    );
                  })
                }

                {activeTab === "trends" && 
                  draftState.monthlyTrends.map((t, i) => (
                    <tr key={`trend-${i}`} className="hover:bg-[#F7FAFC]">
                      <td className="p-3 font-semibold text-[#1A1F36]">{t.month}</td>
                      <td className="p-3 text-right font-mono">{t.patientRequests.toLocaleString()}</td>
                      <td className="p-3 text-right font-mono">{t.admissions.toLocaleString()}</td>
                      <td className="p-3 text-right font-mono text-[#166534] font-bold">{t.serviceAvailability}%</td>
                      <td className="p-3 text-right font-mono">{t.averageLOS} Days</td>
                      <td className="p-3 text-right font-mono">{t.satisfactionScore} / 5.0</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  );
}
