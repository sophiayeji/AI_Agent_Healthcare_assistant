                  <XAxis dataKey="department" interval={0} tick={{ fill: '#64748b', fontSize: 8.5, angle: -25, textAnchor: 'end' }} height={45} />
                  <YAxis domain={[0, 5]} tick={{ fill: '#64748b', fontSize: 9 }} width={35} />
                  <Tooltip />
