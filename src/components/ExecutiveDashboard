          <div id="dept-performance-lines-grid" className="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            {/* Admissions vs requests */}
            <div className="border border-slate-100 rounded-xl p-4 flex flex-col gap-3 chart-card">
              <span className="text-xs font-semibold text-slate-700">Monthly Patient Requests vs Admissions</span>
              <div className="h-[200px]">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={monthlyTrends} margin={{ top: 10, right: 10, left: 15, bottom: 25 }}>
                    <CartesianGrid strokeDasharray="3 3" stroke="#f1f5f9" />
                    <XAxis dataKey="month" interval={0} tick={{ fontSize: 9 }} tickFormatter={(val) => typeof val === 'string' ? val.slice(0, 3) : val} height={35} />
                    <YAxis tick={{ fontSize: 9 }} width={35} />
                    <Tooltip />
                    <Legend wrapperStyle={{ fontSize: 10 }} />
                    <Line type="monotone" dataKey="patientRequests" stroke="#4f46e5" strokeWidth={2} name="Requests" dot={{ r: 4 }} activeDot={{ r: 6 }} />
                    <Line type="monotone" dataKey="admissions" stroke="#10b981" strokeWidth={2} name="Admissions" dot={{ r: 4 }} />
                  </LineChart>
                </ResponsiveContainer>
              </div>
            </div>

            {/* Performance rates trend */}
            <div className="border border-slate-100 rounded-xl p-4 flex flex-col gap-3 chart-card">
              <span className="text-xs font-semibold text-slate-700">Service Availability % vs Admission Rate Trend</span>
              <div className="h-[200px]">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={monthlyTrends} margin={{ top: 10, right: 10, left: 15, bottom: 25 }}>
                    <CartesianGrid strokeDasharray="3 3" stroke="#f1f5f9" />
                    <XAxis dataKey="month" interval={0} tick={{ fontSize: 9 }} tickFormatter={(val) => typeof val === 'string' ? val.slice(0, 3) : val} height={35} />
                    <YAxis domain={[40, 100]} tick={{ fontSize: 9 }} width={35} />
                    <Tooltip />
                    <Legend wrapperStyle={{ fontSize: 10 }} />
                    <Line type="monotone" dataKey="serviceAvailability" stroke="#f59e0b" strokeWidth={2} name="Availability %" dot={{ r: 4 }} />
                    <Line type="monotone" dataKey="requestToAdmissionRate" stroke="#8b5cf6" strokeWidth={2} name="Admission Rate %" dot={{ r: 4 }} />
                  </LineChart>
                </ResponsiveContainer>
              </div>
            </div>

          </div>
        </div>

      </div>

      {/* SECTION 4: LENGTH OF STAY & PATIENT SATISFACTION */}
      <div className="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex flex-col gap-6" id="stay-satisfaction-panel">
        <div className="flex items-center justify-between border-b border-slate-50 pb-4">
          <div className="flex items-center gap-2.5">
            <div className="p-2 bg-indigo-50 text-indigo-600 rounded-lg">
              <Smile size={18} />
            </div>
            <div>
              <h3 className="font-bold text-slate-800 text-base">4. Length of Stay (LOS) & Patient Satisfaction</h3>
              <p className="text-xs text-slate-500">Evaluating clinical discharge efficiency and caregiver ratings</p>
            </div>
          </div>
          
          <button 
            onClick={() => toggleQuestions("stay")}
            className="text-slate-400 hover:text-slate-600 p-1"
            title="View Key Analytical Questions"
          >
            <HelpCircle size={16} />
          </button>
        </div>

        {/* Key Questions Guide Box */}
        {showQuestions === "stay" && (
          <div className="bg-indigo-50 border border-indigo-100 text-indigo-800 p-4 rounded-xl text-xs space-y-1.5 animate-fade-in">
            <h5 className="font-bold flex items-center gap-1.5">
              <HelpCircle size={12} />
              <span>Critical Questions Answered:</span>
            </h5>
            <ul className="list-disc pl-4 space-y-1">
              <li>Which services have the longest average length of stay?</li>
              <li>Which services have the lowest patient satisfaction?</li>
              <li>Is the average length of stay increasing or decreasing?</li>
              <li>Is patient satisfaction improving or declining over time?</li>
              <li>Does a longer length of stay appear to impact patient satisfaction?</li>
            </ul>
          </div>
        )}

        {/* Patient Outcome KPI Cards (YTD) */}
        <div className="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div className="bg-slate-50 rounded-xl p-4 border border-slate-100 flex flex-col justify-between">
            <div className="flex items-center justify-between text-xs text-slate-500 font-medium mb-1.5">
              <span>Average Length of Stay (YTD)</span>
              <span className="py-0.5 px-2 bg-indigo-100 text-indigo-700 font-semibold rounded-full text-[10px]">KPI Target: &lt; 5.0 Days</span>
            </div>
            <div className="flex items-baseline gap-1.5">
              <span className="font-bold text-2xl text-slate-800 font-mono">{avgLOS_YTD} Days</span>
              <span className="text-[10px] text-slate-400">average admission duration</span>
            </div>
          </div>

          <div className="bg-slate-50 rounded-xl p-4 border border-slate-100 flex flex-col justify-between">
            <div className="flex items-center justify-between text-xs text-slate-500 font-medium mb-1.5">
              <span>Patient Satisfaction Score (YTD)</span>
              <span className="py-0.5 px-2 bg-emerald-100 text-emerald-700 font-semibold rounded-full text-[10px]">Rating Index</span>
            </div>
            <div className="flex items-baseline gap-1.5">
              <span className="font-bold text-2xl text-slate-800 font-mono">{avgSatisfactionYTD} / 5.0</span>
              <span className="text-[10px] text-slate-400">average patient feedback</span>
            </div>
          </div>
        </div>

        {/* Current Performance Charts Sub-grid */}
        <div id="stay-satisfaction-bars-grid" className="grid grid-cols-1 md:grid-cols-2 gap-6 pt-2">
          
          {/* LOS by service */}
          <div className="border border-slate-100 rounded-xl p-4 flex flex-col gap-3 chart-card">
            <span className="text-xs font-semibold text-slate-700">Average Length of Stay (Days) by Service Type</span>
            <div className="h-[200px]">
              <ResponsiveContainer width="100%" height="100%">
                <BarChart data={data.lengthOfStaySatisfaction} margin={{ top: 20, right: 5, left: 15, bottom: 35 }}>
                  <CartesianGrid strokeDasharray="3 3" stroke="#f8fafc" />
                  <XAxis dataKey="serviceType" interval={0} tick={{ fill: '#64748b', fontSize: 8.5, angle: -25, textAnchor: 'end' }} height={45} />
                  <YAxis tick={{ fill: '#64748b', fontSize: 9 }} width={35} />
                  <Tooltip />
                  <Bar dataKey="averageLOS" fill="#6366f1" radius={[3, 3, 0, 0]} name="LOS (Days)">
                    <LabelList dataKey="averageLOS" position="top" formatter={(val: any) => `${Number(val).toFixed(1)}d`} className="bar-value-label" offset={4} />
                  </Bar>
                </BarChart>
              </ResponsiveContainer>
            </div>
          </div>

          {/* Satisfaction by service */}
          <div className="border border-slate-100 rounded-xl p-4 flex flex-col gap-3 chart-card">
            <span className="text-xs font-semibold text-slate-700">Average Patient Satisfaction Score (1-5) by Service Type</span>
            <div className="h-[200px]">
              <ResponsiveContainer width="100%" height="100%">
                <BarChart data={data.lengthOfStaySatisfaction} margin={{ top: 20, right: 5, left: 15, bottom: 35 }}>
                  <CartesianGrid strokeDasharray="3 3" stroke="#f8fafc" />
                  <XAxis dataKey="serviceType" interval={0} tick={{ fill: '#64748b', fontSize: 8.5, angle: -25, textAnchor: 'end' }} height={45} />
                  <YAxis domain={[0, 5]} tick={{ fill: '#64748b', fontSize: 9 }} width={35} />
                  <Tooltip />
                  <Bar dataKey="averageSatisfaction" fill="#10b981" radius={[3, 3, 0, 0]} name="Satisfaction Score">
                    <LabelList dataKey="averageSatisfaction" position="top" formatter={(val: any) => Number(val).toFixed(1)} className="bar-value-label" offset={4} />
                  </Bar>
                </BarChart>
              </ResponsiveContainer>
            </div>
          </div>

        </div>

        {/* Monthly Trends curves */}
        <div className="border-t border-slate-100 pt-6">
          <h4 className="text-xs font-bold uppercase tracking-wider text-slate-600 flex items-center gap-1.5 mb-4">
            <TrendingUp size={12} />
            <span>Outcomes & Bed Turnover Trends</span>
          </h4>

          <div id="stay-satisfaction-lines-grid" className="grid grid-cols-1 md:grid-cols-3 gap-6">
            
            {/* LOS Trend vs Satisfaction Trend */}
            <div className="border border-slate-100 rounded-xl p-4 flex flex-col gap-3 col-span-1 md:col-span-2 chart-card">
              <span className="text-xs font-semibold text-slate-700">Average Stay Duration vs Satisfaction Progression</span>
              <div className="h-[200px]">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={monthlyTrends} margin={{ top: 10, right: 15, left: 15, bottom: 25 }}>
                    <CartesianGrid strokeDasharray="3 3" stroke="#f1f5f9" />
                    <XAxis dataKey="month" interval={0} tick={{ fontSize: 9 }} tickFormatter={(val) => typeof val === 'string' ? val.slice(0, 3) : val} height={35} />
                    <YAxis yAxisId="left" domain={[3, 7]} tick={{ fontSize: 9 }} width={30} />
                    <YAxis yAxisId="right" orientation="right" domain={[3, 5]} tick={{ fontSize: 9 }} width={30} />
                    <Tooltip />
                    <Legend wrapperStyle={{ fontSize: 10 }} />
                    <Line yAxisId="left" type="monotone" dataKey="averageLOS" stroke="#6366f1" strokeWidth={2} name="Stay Duration (Days)" dot={{ r: 4 }} />
                    <Line yAxisId="right" type="monotone" dataKey="averageSatisfaction" stroke="#10b981" strokeWidth={2} name="Patient Satisfaction (1-5)" dot={{ r: 4 }} />
                  </LineChart>
                </ResponsiveContainer>
              </div>
            </div>

            {/* Readmission and discharge trends */}
            <div className="border border-slate-100 rounded-xl p-4 flex flex-col gap-3 chart-card">
              <span className="text-xs font-semibold text-slate-700">Turnover: Readmissions & Discharges</span>
              <div className="h-[200px]">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={monthlyTrends} margin={{ top: 10, right: 15, left: 15, bottom: 25 }}>
                    <CartesianGrid strokeDasharray="3 3" stroke="#f1f5f9" />
                    <XAxis dataKey="month" interval={0} tick={{ fontSize: 9 }} tickFormatter={(val) => typeof val === 'string' ? val.slice(0, 3) : val} height={35} />
                    <YAxis yAxisId="left" tick={{ fontSize: 9 }} width={35} />
                    <YAxis yAxisId="right" orientation="right" tick={{ fontSize: 9 }} domain={[0, 10]} width={30} />
                    <Tooltip />
                    <Legend wrapperStyle={{ fontSize: 10 }} />
                    <Line yAxisId="left" type="monotone" dataKey="dischargeTrend" stroke="#8b5cf6" strokeWidth={2} name="Discharges" dot={{ r: 3 }} />
                    <Line yAxisId="right" type="monotone" dataKey="readmissionRate" stroke="#f43f5e" strokeWidth={2} name="Readmissions %" dot={{ r: 3 }} />
                  </LineChart>
                </ResponsiveContainer>
              </div>
            </div>

          </div>
        </div>

      </div>

    </div>
  );
}
