import React, { useState } from "react";
import { 
  BarChart, Bar, LineChart, Line, XAxis, YAxis, CartesianGrid, Tooltip, Legend, ResponsiveContainer, Cell, PieChart, Pie, LabelList 
} from "recharts";
import { 
  Calendar, 
  HelpCircle, 
  Activity, 
  Users, 
  UserCheck, 
  ShieldAlert, 
  Clock, 
  Smile, 
  Heart,
  TrendingUp,
  Inbox,
  AlertCircle,
  Printer
} from "lucide-react";
import { DashboardData } from "../types";
import AIAnalystReport from "./AIAnalystReport";

interface ExecutiveDashboardProps {
  data: DashboardData;
  onNotify: (msg: string, type: "success" | "error" | "info") => void;
  isAdminPreview?: boolean;
}

const COLORS = ["#4f46e5", "#10b981", "#8b5cf6", "#f59e0b", "#3b82f6", "#ef4444"];

export default function ExecutiveDashboard({ data, onNotify, isAdminPreview = false }: ExecutiveDashboardProps) {
  const [selectedMonth, setSelectedMonth] = useState<string>("YTD");
  const [showQuestions, setShowQuestions] = useState<string | null>(null);

  // Filters monthly data or holds full YTD
  const monthlyTrends = data.monthlyTrends;

  // Compute calculated metrics YTD for department performance cards
  const totalRequestsYTD = monthlyTrends.reduce((sum, t) => sum + t.patientRequests, 0);
  const totalAdmissionsYTD = monthlyTrends.reduce((sum, t) => sum + t.admissions, 0);
  const avgAdmissionRateYTD = Math.round((totalAdmissionsYTD / Math.max(1, totalRequestsYTD)) * 100);
  const avgAvailabilityYTD = Math.round(monthlyTrends.reduce((sum, t) => sum + t.serviceAvailability, 0) / monthlyTrends.length);

  // Compute calculated metrics YTD for Length of Stay / Patient Satisfaction
  const totalStayFractions = data.lengthOfStaySatisfaction.reduce((sum, l) => sum + l.averageLOS, 0);
  const avgLOS_YTD = parseFloat((totalStayFractions / data.lengthOfStaySatisfaction.length).toFixed(1));
  const totalSatisfactionFractions = data.lengthOfStaySatisfaction.reduce((sum, l) => sum + l.averageSatisfaction, 0);
  const avgSatisfactionYTD = parseFloat((totalSatisfactionFractions / data.lengthOfStaySatisfaction.length).toFixed(1));

  const monthsList = data.monthlyTrends && data.monthlyTrends.length > 0 
    ? data.monthlyTrends.map(t => t.month)
    : ["January", "February", "March", "April", "May"];

  const getDetectedYear = (pStr: string) => {
    if (!pStr) return "2026";
    const normalized = pStr.replace(/[–—]/g, "-");
    const match = normalized.match(/(\d{1,2})\/(\d{1,2})\/(\d{2,4})\s*-\s*(\d{1,2})\/(\d{1,2})\/(\d{2,4})/);
    if (match) {
      const endY = match[6];
      return endY.length === 2 ? `20${endY}` : endY;
    }
    const yearMatch = pStr.match(/\b(202\d|201\d)\b/);
    if (yearMatch) return yearMatch[1];
    return "2026";
  };

  const detectedYear = getDetectedYear(data.period);

  // Toggle active questions
  const toggleQuestions = (section: string) => {
    setShowQuestions(showQuestions === section ? null : section);
  };

  return (
    <div className="space-y-8" id="executive-dashboard-container">
      {/* Printable Report Header (Visible only on paper/PDF print) */}
      <div className="print-header">
        <div className="flex items-center justify-between border-b-2 border-[#4F46E5] pb-4 mb-6">
          <div>
            <h1 className="text-2xl font-black text-[#1A1F36] tracking-tight">Sophia Medical Group</h1>
            <p className="text-xs font-mono font-bold tracking-widest text-[#697386] uppercase">
              Clinical Operations Performance Report
            </p>
          </div>
          <div className="text-right">
            <span className="text-xs font-semibold text-[#1A1F36] block">
              Period Scope: {selectedMonth === "YTD" ? `Year-To-Date (YTD) ${monthsList[0].substring(0, 3)} - ${monthsList[monthsList.length - 1].substring(0, 3)} ${detectedYear}` : `${selectedMonth} ${detectedYear}`}
            </span>
            <span className="text-[10px] font-mono text-slate-500 block">
              Generated: {new Date().toLocaleDateString()}
            </span>
          </div>
        </div>
      </div>

      {/* Upper Status & Date Filters */}
      <div className="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex flex-col xl:flex-row xl:items-center justify-between gap-6 no-print">
        <div>
          <div className="flex items-center gap-2 mb-1.5">
            <span className={`w-2.5 h-2.5 rounded-full ${isAdminPreview ? "bg-amber-500 animate-pulse" : "bg-emerald-500"}`} />
            <h2 className="font-bold text-slate-800 text-xl tracking-tight">
              {isAdminPreview ? "Interactive Draft Preview" : "Executive Operations Console"}
            </h2>
          </div>
          <p className="text-xs text-slate-500 font-sans flex items-center gap-2">
            <span>Period Scope:</span>
            <span className="date-badge ml-1.5">{data.period}</span>
            <span>&bull;</span>
            <span>Last Synced:</span>
            <span className="font-mono text-slate-600">{new Date(data.lastUpdated).toLocaleDateString()} {new Date(data.lastUpdated).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}</span>
          </p>
        </div>

        {/* Filters and Actions Group */}
        <div className="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
          {/* Date Filter Panel */}
          <div className="flex flex-col sm:flex-row items-start sm:items-center gap-3 bg-slate-50 p-2.5 rounded-xl border border-slate-200/50">
            <div className="flex items-center gap-1.5 text-slate-500 text-xs font-semibold px-2 shrink-0">
              <Calendar size={14} className="text-blue-500" />
              <span>Scope Filter:</span>
            </div>

            <div className="flex flex-wrap gap-1.5 w-full sm:w-auto">
              <button
                onClick={() => {
                  setSelectedMonth("YTD");
                  onNotify("Dashboard scope changed to Year-To-Date (YTD) cumulative metrics", "info");
                }}
                className={`py-1.5 px-3 rounded-lg text-xs font-semibold tracking-wide transition-all cursor-pointer ${
                  selectedMonth === "YTD"
                    ? "bg-blue-600 text-white shadow-sm font-bold"
                    : "bg-white text-slate-700 hover:bg-slate-100 border border-slate-200"
                }`}
              >
                YTD ({monthsList[0].substring(0, 3)} - {monthsList[monthsList.length - 1].substring(0, 3)})
              </button>

              {monthsList.map(m => (
                <button
                  key={m}
                  onClick={() => {
                    setSelectedMonth(m);
                    onNotify(`Dashboard scope changed to ${m} ${detectedYear} monthly metrics`, "info");
                  }}
                  className={`py-1.5 px-3 rounded-lg text-xs font-medium transition-all cursor-pointer ${
                    selectedMonth === m
                      ? "bg-indigo-600 text-white shadow-sm font-semibold"
                      : "bg-white text-slate-600 hover:bg-slate-100 border border-slate-200"
                  }`}
                >
                  {m.substring(0, 3)}
                </button>
              ))}
            </div>
          </div>

          {/* Quick High-Fidelity Print Trigger */}
          <button
            onClick={() => {
              onNotify("Optimizing layouts for high-fidelity clinical report printing...", "success");
              // Allow notification toaster to render before opening print dialog
              setTimeout(() => {
                window.print();
              }, 300);
            }}
            className="flex items-center justify-center gap-2 py-3 px-4 rounded-xl bg-[#1A1F36] hover:bg-[#2D3748] text-white text-xs font-bold shadow-sm hover:shadow transition-all shrink-0 cursor-pointer border border-[#1A1F36]"
            title="Export graphs and analytics report to high-fidelity physical page or PDF document"
          >
            <Printer size={14} />
            <span>Print Executive Report</span>
          </button>
        </div>
      </div>

      {/* AI OPERATIONS ANALYST MODULE */}
      <AIAnalystReport 
        dashboardData={data} 
        selectedMonth={selectedMonth} 
        onNotify={onNotify} 
      />

      {/* SECTIONS 1 & 2: CURRENT SNAPSHOT / YTD OVERVIEW */}
      <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
        
        {/* SECTION 1: Patient Demographics */}
        <div className="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex flex-col gap-6" id="patient-demographics-card">
          <div className="flex items-center justify-between border-b border-slate-50 pb-4">
            <div className="flex items-center gap-2.5">
              <div className="p-2 bg-blue-50 text-blue-600 rounded-lg">
                <Users size={18} />
              </div>
              <div>
                <h3 className="font-bold text-slate-800 text-base">1. Patient Demographics Profile</h3>
                <p className="text-xs text-slate-500">Volume and clinical intake distribution patterns</p>
              </div>
            </div>
            
            <button 
              onClick={() => toggleQuestions("demographics")}
              className="text-slate-400 hover:text-slate-600 p-1"
              title="View Key Analytical Questions"
            >
              <HelpCircle size={16} />
            </button>
          </div>

          {/* Key Questions Guide Box */}
          {showQuestions === "demographics" && (
            <div className="bg-blue-50 border border-blue-100 text-blue-800 p-4 rounded-xl text-xs space-y-1.5 animate-fade-in">
              <h5 className="font-bold flex items-center gap-1.5">
                <HelpCircle size={12} />
                <span>Critical Questions Answered:</span>
              </h5>
              <ul className="list-disc pl-4 space-y-1">
                <li>Which age groups utilize hospital services the most?</li>
                <li>Which service types have the highest patient volume?</li>
                <li>Are certain patient groups driving demand and when?</li>
              </ul>
            </div>
          )}

          {/* Demographics Charts Grid */}
          <div id="demographics-charts-grid" className="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            {/* Age Distribution */}
            <div className="flex flex-col gap-3 chart-card">
              <span className="text-xs font-semibold text-slate-600 text-center">Patients by Age Group (YTD)</span>
              <div className="h-[220px]">
                <ResponsiveContainer width="100%" height="100%">
                  <BarChart data={data.patientDemographics.ageGroups} margin={{ top: 20, right: 10, left: 10, bottom: 25 }}>
                    <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#f1f5f9" />
                    <XAxis dataKey="group" interval={0} tick={{ fill: '#64748b', fontSize: 10 }} height={35} />
                    <YAxis tick={{ fill: '#64748b', fontSize: 10 }} width={35} />
                    <Tooltip cursor={{ fill: '#f8fafc' }} contentStyle={{ fontSize: 11, borderRadius: 8, border: "1px solid #e2e8f0" }} />
                    <Bar dataKey="count" name="Patient Count" fill="#4f46e5" radius={[4, 4, 0, 0]}>
                      {data.patientDemographics.ageGroups.map((entry, index) => (
                        <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />
                      ))}
                      <LabelList dataKey="count" position="top" className="bar-value-label" offset={6} />
                    </Bar>
                  </BarChart>
                </ResponsiveContainer>
              </div>
            </div>

            {/* Service Volume */}
            <div className="flex flex-col gap-3 chart-card">
              <span className="text-xs font-semibold text-slate-600 text-center">Inpatient Volume by Specialty (YTD)</span>
              <div className="h-[220px]">
                <ResponsiveContainer width="100%" height="100%">
                  <PieChart>
                    <Pie
                      data={data.patientDemographics.serviceTypes}
                      cx="50%"
                      cy="42%"
                      innerRadius={35}
                      outerRadius={50}
                      paddingAngle={3}
                      dataKey="count"
                      nameKey="service"
                      label={false}
                    >
                      {data.patientDemographics.serviceTypes.map((entry, index) => (
                        <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />
                      ))}
                    </Pie>
                    <Tooltip contentStyle={{ fontSize: 11, borderRadius: 8 }} />
                    <Legend 
                      iconSize={8} 
                      iconType="circle" 
                      wrapperStyle={{ fontSize: 9.5, bottom: 0 }} 
                      formatter={(value, entry: any) => {
                        const count = entry.payload?.count;
                        return `${value}: ${count ? count.toLocaleString() : ''}`;
                      }}
                    />
                  </PieChart>
                </ResponsiveContainer>
              </div>
            </div>

          </div>
        </div>

        {/* SECTION 2: Staff Demographics & Availability */}
        <div className="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex flex-col gap-6" id="staff-demographics-card">
          <div className="flex items-center justify-between border-b border-slate-50 pb-4">
            <div className="flex items-center gap-2.5">
              <div className="p-2 bg-indigo-50 text-indigo-600 rounded-lg">
                <UserCheck size={18} />
              </div>
              <div>
                <h3 className="font-bold text-slate-800 text-base">2. Staff Coverage & Availability</h3>
                <p className="text-xs text-slate-500">Workforce distribution and attendance metrics</p>
              </div>
            </div>
            
            <button 
              onClick={() => toggleQuestions("staffing")}
              className="text-slate-400 hover:text-slate-600 p-1"
              title="View Key Analytical Questions"
            >
              <HelpCircle size={16} />
            </button>
          </div>

          {/* Key Questions Guide Box */}
          {showQuestions === "staffing" && (
            <div className="bg-indigo-50 border border-indigo-100 text-indigo-800 p-4 rounded-xl text-xs space-y-1.5 animate-fade-in">
              <h5 className="font-bold flex items-center gap-1.5">
                <HelpCircle size={12} />
                <span>Critical Questions Answered:</span>
              </h5>
              <ul className="list-disc pl-4 space-y-1">
                <li>Which departments have the highest and lowest staffing levels?</li>
                <li>Are there departments with low staff presence rates?</li>
                <li>Could staffing shortages impact hospital operations?</li>
              </ul>
            </div>
          )}

          {/* Staffing Charts Grid */}
          <div id="staffing-charts-grid" className="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            {/* Staff Count by Dept */}
            <div className="flex flex-col gap-3 chart-card">
              <span className="text-xs font-semibold text-slate-600 text-center">FTE Count by Department</span>
              <div className="h-[220px]">
                <ResponsiveContainer width="100%" height="100%">
                  <BarChart data={data.staffData} margin={{ top: 10, right: 30, left: 10, bottom: 5 }} layout="vertical">
                    <CartesianGrid strokeDasharray="3 3" horizontal={false} stroke="#f1f5f9" />
                    <XAxis type="number" tick={{ fill: '#64748b', fontSize: 10 }} />
                    <YAxis dataKey="department" type="category" tick={{ fill: '#64748b', fontSize: 10 }} width={100} />
                    <Tooltip contentStyle={{ fontSize: 11, borderRadius: 8 }} />
                    <Bar dataKey="staffCount" name="FTE Count" fill="#8b5cf6" radius={[0, 4, 4, 0]}>
                      <LabelList dataKey="staffCount" position="right" className="bar-value-label" offset={6} />
                    </Bar>
                  </BarChart>
                </ResponsiveContainer>
              </div>
            </div>

            {/* Presence Rate by Dept */}
            <div className="flex flex-col gap-3 chart-card">
              <span className="text-xs font-semibold text-slate-600 text-center">Average Staff Presence Rate (%)</span>
              <div className="h-[220px]">
                <ResponsiveContainer width="100%" height="100%">
                  <BarChart data={data.staffData} margin={{ top: 20, right: 10, left: 10, bottom: 35 }}>
                    <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#f1f5f9" />
                    <XAxis dataKey="department" interval={0} tick={{ fill: '#64748b', fontSize: 8.5, angle: -25, textAnchor: 'end' }} height={45} />
                    <YAxis domain={[50, 100]} tick={{ fill: '#64748b', fontSize: 10 }} width={35} />
                    <Tooltip contentStyle={{ fontSize: 11, borderRadius: 8 }} />
                    <Bar dataKey="presenceRate" name="Presence %" fill="#06b6d4" radius={[4, 4, 0, 0]}>
                      {data.staffData.map((entry, index) => (
                        <Cell key={`cell-${index}`} fill={entry.presenceRate < 85 ? "#ef4444" : "#10b981"} />
                      ))}
                      <LabelList dataKey="presenceRate" position="top" formatter={(val: any) => `${val}%`} className="bar-value-label" offset={6} />
                    </Bar>
                  </BarChart>
                </ResponsiveContainer>
              </div>
            </div>

          </div>
        </div>

      </div>

      {/* SECTION 3: DEPARTMENT SERVICE PERFORMANCE */}
      <div className="bg-white rounded-2xl p-6 shadow-sm border border-slate-100 flex flex-col gap-6" id="dept-performance-panel">
        <div className="flex items-center justify-between border-b border-slate-50 pb-4">
          <div className="flex items-center gap-2.5">
            <div className="p-2 bg-emerald-50 text-emerald-600 rounded-lg">
              <Activity size={18} />
            </div>
            <div>
              <h3 className="font-bold text-slate-800 text-base">3. Department Service Performance</h3>
              <p className="text-xs text-slate-500">Workforce outputs, availability rates, and monthly trend curves</p>
            </div>
          </div>
          
          <button 
            onClick={() => toggleQuestions("performance")}
            className="text-slate-400 hover:text-slate-600 p-1"
            title="View Key Analytical Questions"
          >
            <HelpCircle size={16} />
          </button>
        </div>

        {/* Key Questions Guide Box */}
        {showQuestions === "performance" && (
          <div className="bg-emerald-50 border border-emerald-100 text-emerald-800 p-4 rounded-xl text-xs space-y-1.5 animate-fade-in">
            <h5 className="font-bold flex items-center gap-1.5">
              <HelpCircle size={12} />
              <span>Critical Questions Answered:</span>
            </h5>
            <ul className="list-disc pl-4 space-y-1">
              <li>Which departments have the highest and lowest service performance?</li>
              <li>Which departments are experiencing declining performance?</li>
              <li>Are patient requests increasing faster than admissions?</li>
              <li>Is service availability improving or worsening over time?</li>
              <li>Do satisfaction or morale trends correlate with operational performance?</li>
            </ul>
          </div>
        )}

        {/* KPI Cards (YTD) */}
        <div className="grid grid-cols-1 sm:grid-cols-3 gap-5">
          <div className="bg-slate-50 rounded-xl p-4 border border-slate-100 flex flex-col justify-between">
            <div className="flex items-center justify-between text-xs text-slate-500 font-medium mb-1.5">
              <span>Patient Request Volume (YTD)</span>
              <span className="py-0.5 px-2 bg-blue-100 text-blue-700 font-semibold rounded-full text-[10px]">Inpatient</span>
            </div>
            <div className="flex items-baseline gap-1.5">
              <span className="font-bold text-2xl text-slate-800 font-mono">{totalRequestsYTD.toLocaleString()}</span>
              <span className="text-[10px] text-slate-400">Requests</span>
            </div>
          </div>

          <div className="bg-slate-50 rounded-xl p-4 border border-slate-100 flex flex-col justify-between">
            <div className="flex items-center justify-between text-xs text-slate-500 font-medium mb-1.5">
              <span>Admission Conversion Rate (YTD)</span>
              <span className="py-0.5 px-2 bg-emerald-100 text-emerald-700 font-semibold rounded-full text-[10px]">Average</span>
            </div>
            <div className="flex items-baseline gap-1.5">
              <span className="font-bold text-2xl text-slate-800 font-mono">{avgAdmissionRateYTD}%</span>
              <span className="text-[10px] text-slate-400">of requests admitted</span>
            </div>
          </div>

          <div className="bg-slate-50 rounded-xl p-4 border border-slate-100 flex flex-col justify-between">
            <div className="flex items-center justify-between text-xs text-slate-500 font-medium mb-1.5">
              <span>Service Availability Rating (YTD)</span>
              <span className="py-0.5 px-2 bg-indigo-100 text-indigo-700 font-semibold rounded-full text-[10px]">Bed Capacity</span>
            </div>
            <div className="flex items-baseline gap-1.5">
              <span className="font-bold text-2xl text-slate-800 font-mono">{avgAvailabilityYTD}%</span>
              <span className="text-[10px] text-slate-400">available beds</span>
            </div>
          </div>
        </div>

        {/* Current Performance Sub-grid */}
        <div id="dept-performance-bars-grid" className="grid grid-cols-1 lg:grid-cols-3 gap-6 pt-2">
          
          {/* Request-to-admission rate */}
          <div className="border border-slate-100 rounded-xl p-4 flex flex-col gap-3 chart-card">
            <span className="text-xs font-semibold text-slate-700">Request-to-Admission Rate (%) by Department</span>
            <div className="h-[180px]">
              <ResponsiveContainer width="100%" height="100%">
                <BarChart data={data.departmentPerformance} margin={{ top: 20, right: 5, left: 15, bottom: 35 }}>
                  <CartesianGrid strokeDasharray="3 3" stroke="#f8fafc" />
                  <XAxis dataKey="department" interval={0} tick={{ fill: '#64748b', fontSize: 8.5, angle: -25, textAnchor: 'end' }} height={45} />
                  <YAxis tick={{ fill: '#64748b', fontSize: 9 }} width={35} />
                  <Tooltip />
                  <Bar dataKey="requestToAdmissionRate" fill="#4f46e5" radius={[3, 3, 0, 0]} name="Admission Rate %">
                    <LabelList dataKey="requestToAdmissionRate" position="top" formatter={(val: any) => `${val}%`} className="bar-value-label" offset={4} />
                  </Bar>
                </BarChart>
              </ResponsiveContainer>
            </div>
          </div>

          {/* Service Availability */}
          <div className="border border-slate-100 rounded-xl p-4 flex flex-col gap-3 chart-card">
            <span className="text-xs font-semibold text-slate-700">Service Availability (%) by Department</span>
            <div className="h-[180px]">
              <ResponsiveContainer width="100%" height="100%">
                <BarChart data={data.departmentPerformance} margin={{ top: 20, right: 5, left: 15, bottom: 35 }}>
                  <CartesianGrid strokeDasharray="3 3" stroke="#f8fafc" />
                  <XAxis dataKey="department" interval={0} tick={{ fill: '#64748b', fontSize: 8.5, angle: -25, textAnchor: 'end' }} height={45} />
                  <YAxis tick={{ fill: '#64748b', fontSize: 9 }} width={35} />
                  <Tooltip />
                  <Bar dataKey="serviceAvailability" fill="#10b981" radius={[3, 3, 0, 0]} name="Availability %">
                    <LabelList dataKey="serviceAvailability" position="top" formatter={(val: any) => `${val}%`} className="bar-value-label" offset={4} />
                  </Bar>
                </BarChart>
              </ResponsiveContainer>
            </div>
          </div>

          {/* Morale/Satisfaction Score */}
          <div className="border border-slate-100 rounded-xl p-4 flex flex-col gap-3 chart-card">
            <span className="text-xs font-semibold text-slate-700">Clinician Morale / Satisfaction by Department</span>
            <div className="h-[180px]">
              <ResponsiveContainer width="100%" height="100%">
